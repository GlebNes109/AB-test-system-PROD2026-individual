        {
          "name": "0.07 GET users → find IDs",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
            "var users = pm.response.json().items;",
            "function findId(email) { var u = users.find(function(x){return x.email===email;}); return u ? u.id : null; }",
            "",
            "var expId = findId('b3_experimenter@demo.com');",
            "var alphaId = findId('b3_approver_alpha@demo.com');",
            "var betaId = findId('b3_approver_beta@demo.com');",
            "",
            "if (expId) pm.collectionVariables.set('EXPERIMENTER_ID', expId);",
            "if (alphaId) pm.collectionVariables.set('APPROVER_ALPHA_ID', alphaId);",
            "if (betaId) pm.collectionVariables.set('APPROVER_BETA_ID', betaId);",
            "",
            "pm.test('Found experimenter', function () { pm.expect(expId).to.not.be.null; });",
            "pm.test('Found approver_alpha', function () { pm.expect(alphaId).to.not.be.null; });",
            "pm.test('Found approver_beta', function () { pm.expect(betaId).to.not.be.null; });",
            "",
            "console.log('[gen] EXPERIMENTER_ID=' + expId);",
            "console.log('[gen] APPROVER_ALPHA_ID=' + alphaId);",
            "console.log('[gen] APPROVER_BETA_ID=' + betaId);"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{ADMIN_TOKEN}}" }],
            "url": { "raw": "{{BASE_URL}}/api/v1/users?size=100", "host": ["{{BASE_URL}}"], "path": ["api","v1","users"], "query": [{"key":"size","value":"100"}] }
          }
        },
