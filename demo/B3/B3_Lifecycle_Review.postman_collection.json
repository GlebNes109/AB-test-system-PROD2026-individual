{
  "info": {
    "name": "B3. Жизненный цикл и ревью экспериментов",
    "description": "Коллекция для проверки критериев B3.\n\nПорядок работы:\n1. Запустить папку «0. Data Generator» через Collection Runner (ПКМ → Run folder) — создаст все сущности и сохранит ID/токены в переменные\n2. Выполнять запросы B3-1 … B3-5 вручную по одному\n\nПодготовка: docker compose up -d",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "BASE_URL", "value": "http://localhost", "type": "string" },
    { "key": "ADMIN_TOKEN", "value": "", "type": "string" },
    { "key": "EXPERIMENTER_TOKEN", "value": "", "type": "string" },
    { "key": "APPROVER_ALPHA_TOKEN", "value": "", "type": "string" },
    { "key": "APPROVER_BETA_TOKEN", "value": "", "type": "string" },
    { "key": "APPROVER_OUTSIDER_TOKEN", "value": "", "type": "string" },
    { "key": "VIEWER_TOKEN", "value": "", "type": "string" },
    { "key": "EXPERIMENTER_ID", "value": "", "type": "string" },
    { "key": "APPROVER_ALPHA_ID", "value": "", "type": "string" },
    { "key": "APPROVER_BETA_ID", "value": "", "type": "string" },
    { "key": "EXP_LIFECYCLE", "value": "", "type": "string" },
    { "key": "EXP_APPROVAL", "value": "", "type": "string" },
    { "key": "EXP_BLOCK_START", "value": "", "type": "string" },
    { "key": "EXP_BAD_TRANSITION", "value": "", "type": "string" },
    { "key": "EXP_ROLE_POLICY", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "0. Data Generator (Run folder)",
      "description": "Запустите эту папку через Collection Runner (ПКМ → Run folder → Run).\nСоздаёт всех пользователей, флаги, эксперименты и сохраняет ID/токены в переменные коллекции.\n\nПосле прогона все переменные (EXP_LIFECYCLE, EXPERIMENTER_TOKEN и т.д.) будут заполнены автоматически.",
      "item": [
        {
          "name": "0.01 Login admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('ADMIN_TOKEN', json.accessToken);",
                  "console.log('[gen] Admin logged in');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@mail.ru\",\n  \"password\": \"123123123aA!\"\n}" },
            "url": { "raw": "{{BASE_URL}}/api/v1/auth/login", "host": ["{{BASE_URL}}"], "path": ["api","v1","auth","login"] }
          }
        },
        {
          "name": "0.02 Create user: experimenter",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('201 or 409', function () { pm.expect([201,409]).to.include(pm.response.code); });"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{ADMIN_TOKEN}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"b3_experimenter@demo.com\",\n  \"password\": \"Demo1234!x\",\n  \"role\": \"EXPERIMENTER\"\n}" },
            "url": { "raw": "{{BASE_URL}}/api/v1/users", "host": ["{{BASE_URL}}"], "path": ["api","v1","users"] }
          }
        },
