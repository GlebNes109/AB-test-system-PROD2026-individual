    {
      "name": "B2-1. Флаг без активного эксперимента → default",
      "item": [
        {
          "name": "B2-1: decision (b2_no_experiment)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('value = fallback_value (default флага)', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.be.an('array').with.lengthOf(1);",
                  "    pm.expect(json[0].value).to.eql('fallback_value');",
                  "});",
                  "",
                  "pm.test('id = null (решение по эксперименту не создавалось)', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json[0].id).to.be.null;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"user-001\",\n  \"subject_attr\": {},\n  \"flags_keys\": [\"b2_no_experiment\"]\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/v1/decision",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "v1", "decision"]
            }
          }
        }
      ]
    },
    {
      "name": "B2-2. Таргетинг: пользователь проходит / не проходит",
      "item": [
        {
          "name": "B2-2a: таргетинг пройден (country=RU)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('id != null — пользователь попал в эксперимент', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.be.an('array').with.lengthOf(1);",
                  "    pm.expect(json[0].id).to.not.be.null;",
                  "});",
                  "",
                  "pm.test('value — один из вариантов эксперимента (не default)', function () {",
                  "    var json = pm.response.json();",
                  "    var allowed = ['default_color_variant', 'red_variant'];",
                  "    pm.expect(allowed).to.include(json[0].value);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
