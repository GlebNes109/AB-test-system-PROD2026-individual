{
  "info": {
    "name": "B2. Feature Flags и выдача вариантов",
    "description": "Коллекция для проверки критериев B2 (Feature Flags и выдача вариантов).\n\nПодготовка:\n1. docker compose up -d\n2. Запустить папку «0. Data Generator» через Collection Runner (ПКМ → Run folder → Run)\n3. Базовая переменная BASE_URL задана по умолчанию: http://localhost",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {"key": "BASE_URL", "value": "http://localhost", "type": "string"},
    {"key": "ADMIN_TOKEN", "value": "", "type": "string"},
    {"key": "EXPERIMENTER_ID", "value": "", "type": "string"},
    {"key": "APPROVER_ID", "value": "", "type": "string"},
    {"key": "EXP_TARGETING_ID", "value": "", "type": "string"},
    {"key": "EXP_VARIANT_ID", "value": "", "type": "string"},
    {"key": "EXP_WEIGHTS_ID", "value": "", "type": "string"}
  ],
  "item": [
    {
      "name": "0. Data Generator",
      "description": "Запустить через Collection Runner: ПКМ на папке → Run folder → Run.\nСоздаёт: 2 пользователя, approver group, event type, metric, 4 feature flags, 3 эксперимента (RUNNING).\nВсе переменные коллекции заполняются автоматически.",
      "item": [
        {
          "name": "1. Login (admin)",
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": [
            "pm.test('Status 200', function() { pm.response.to.have.status(200); });",
            "pm.collectionVariables.set('ADMIN_TOKEN', pm.response.json().accessToken);"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"email\": \"admin@mail.ru\",\n  \"password\": \"123123123aA!\"\n}"},
            "url": {"raw": "{{BASE_URL}}/api/v1/auth/login", "host": ["{{BASE_URL}}"], "path": ["api","v1","auth","login"]}
          }
        },
        {
          "name": "2. Создать experimenter",
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": [
            "pm.test('Создан или существует', function() { pm.expect([201, 409]).to.include(pm.response.code); });"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{ADMIN_TOKEN}}"}],
            "body": {"mode": "raw", "raw": "{\n  \"email\": \"b2_experimenter@demo.com\",\n  \"password\": \"Demo1234!x\",\n  \"role\": \"EXPERIMENTER\"\n}"},
            "url": {"raw": "{{BASE_URL}}/api/v1/users", "host": ["{{BASE_URL}}"], "path": ["api","v1","users"]}
          }
        },
        {
          "name": "3. Создать approver",
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": [
            "pm.test('Создан или существует', function() { pm.expect([201, 409]).to.include(pm.response.code); });"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{ADMIN_TOKEN}}"}],
            "body": {"mode": "raw", "raw": "{\n  \"email\": \"b2_approver@demo.com\",\n  \"password\": \"Demo1234!x\",\n  \"role\": \"APPROVER\"\n}"},
            "url": {"raw": "{{BASE_URL}}/api/v1/users", "host": ["{{BASE_URL}}"], "path": ["api","v1","users"]}
          }
        },
        {
          "name": "4. GET users → save IDs",
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": [
            "pm.test('Status 200', function() { pm.response.to.have.status(200); });",
            "var users = pm.response.json().items || [];",
            "var exp = users.find(function(u) { return u.email === 'b2_experimenter@demo.com'; });",
            "var app = users.find(function(u) { return u.email === 'b2_approver@demo.com'; });",
            "if (exp) { pm.collectionVariables.set('EXPERIMENTER_ID', exp.id); console.log('EXPERIMENTER_ID:', exp.id); }",
            "if (app) { pm.collectionVariables.set('APPROVER_ID', app.id); console.log('APPROVER_ID:', app.id); }"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{ADMIN_TOKEN}}"}],
            "url": {"raw": "{{BASE_URL}}/api/v1/users?size=100", "host": ["{{BASE_URL}}"], "path": ["api","v1","users"], "query": [{"key": "size", "value": "100"}]}
          }
        },
        {
          "name": "5. SET approver group",
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": [
            "pm.test('Status 200', function() { pm.response.to.have.status(200); });"
          ]}}],
          "request": {
            "method": "PUT",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{ADMIN_TOKEN}}"}],
            "body": {"mode": "raw", "raw": "{\n  \"approver_ids\": [\"{{APPROVER_ID}}\"],\n  \"min_approvals\": 1\n}"},
            "url": {"raw": "{{BASE_URL}}/api/v1/users/{{EXPERIMENTER_ID}}/approvers", "host": ["{{BASE_URL}}"], "path": ["api","v1","users","{{EXPERIMENTER_ID}}","approvers"]}
          }
        },
        {
          "name": "6. Create event type (exposure)",
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": [
            "pm.test('Создан или существует', function() { pm.expect([201, 409]).to.include(pm.response.code); });"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{ADMIN_TOKEN}}"}],
            "body": {"mode": "raw", "raw": "{\n  \"type\": \"exposure\",\n  \"description\": \"Показ элемента\"\n}"},
            "url": {"raw": "{{BASE_URL}}/api/v1/events/types", "host": ["{{BASE_URL}}"], "path": ["api","v1","events","types"]}
          }
        },
        {
          "name": "7. Create metric (exposure_count)",
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": [
            "pm.test('Создан или существует', function() { pm.expect([201, 409]).to.include(pm.response.code); });"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{ADMIN_TOKEN}}"}],
            "body": {"mode": "raw", "raw": "{\n  \"key\": \"exposure_count\",\n  \"name\": \"Число показов\",\n  \"description\": \"COUNT exposure\",\n  \"event_type\": \"exposure\",\n  \"aggregation\": \"COUNT\"\n}"},
            "url": {"raw": "{{BASE_URL}}/api/v1/metrics", "host": ["{{BASE_URL}}"], "path": ["api","v1","metrics"]}
          }
        },
        {
          "name": "8. Create flag b2_no_experiment",
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": [
            "pm.test('Создан или существует', function() { pm.expect([201, 409]).to.include(pm.response.code); });"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{ADMIN_TOKEN}}"}],
            "body": {"mode": "raw", "raw": "{\n  \"key\": \"b2_no_experiment\",\n  \"type\": \"string\",\n  \"default_value\": \"fallback_value\",\n  \"description\": \"B2-1: флаг без активного эксперимента\"\n}"},
            "url": {"raw": "{{BASE_URL}}/api/v1/feature-flags", "host": ["{{BASE_URL}}"], "path": ["api","v1","feature-flags"]}
          }
        },
        {
          "name": "9. Create flag b2_targeting",
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": [
            "pm.test('Создан или существует', function() { pm.expect([201, 409]).to.include(pm.response.code); });"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{ADMIN_TOKEN}}"}],
            "body": {"mode": "raw", "raw": "{\n  \"key\": \"b2_targeting\",\n  \"type\": \"string\",\n  \"default_value\": \"default_color_defaultvalue\",\n  \"description\": \"B2-2: флаг с таргетингом country == RU\"\n}"},
            "url": {"raw": "{{BASE_URL}}/api/v1/feature-flags", "host": ["{{BASE_URL}}"], "path": ["api","v1","feature-flags"]}
          }
        },
        {
          "name": "10. Create flag b2_variant",
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": [
            "pm.test('Создан или существует', function() { pm.expect([201, 409]).to.include(pm.response.code); });"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{ADMIN_TOKEN}}"}],
            "body": {"mode": "raw", "raw": "{\n  \"key\": \"b2_variant\",\n  \"type\": \"string\",\n  \"default_value\": \"old_design_defaultvalue\",\n  \"description\": \"B2-3/B2-4: флаг с экспериментом без таргетинга\"\n}"},
            "url": {"raw": "{{BASE_URL}}/api/v1/feature-flags", "host": ["{{BASE_URL}}"], "path": ["api","v1","feature-flags"]}
          }
        },
        {
          "name": "11. Create flag b2_weights",
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": [
            "pm.test('Создан или существует', function() { pm.expect([201, 409]).to.include(pm.response.code); });"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{ADMIN_TOKEN}}"}],
            "body": {"mode": "raw", "raw": "{\n  \"key\": \"b2_weights\",\n  \"type\": \"string\",\n  \"default_value\": \"control_val\",\n  \"description\": \"B2-5: флаг для проверки распределения весов\"\n}"},
            "url": {"raw": "{{BASE_URL}}/api/v1/feature-flags", "host": ["{{BASE_URL}}"], "path": ["api","v1","feature-flags"]}
          }
        },
        {
          "name": "12. EXP b2_targeting: Создать (DRAFT)",
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": [
            "pm.test('Status 201', function() { pm.response.to.have.status(201); });",
            "pm.collectionVariables.set('EXP_TARGETING_ID', pm.response.json().id);",
            "console.log('EXP_TARGETING_ID:', pm.response.json().id);"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{ADMIN_TOKEN}}"}],
            "body": {"mode": "raw", "raw": "{\n  \"name\": \"B2-2: таргетинг country\",\n  \"feature_flag_key\": \"b2_targeting\",\n  \"targeting_rule\": \"country == \\\"RU\\\"\",\n  \"audience_percentage\": 100,\n  \"variants\": [\n    {\"name\": \"control\",   \"value\": \"default_color_variant\", \"weight\": 50, \"is_control\": true},\n    {\"name\": \"treatment\", \"value\": \"red_variant\",           \"weight\": 50, \"is_control\": false}\n  ],\n  \"metrics\": [{\"metric_key\": \"exposure_count\", \"type\": \"PRIMARY\"}]\n}"},
            "url": {"raw": "{{BASE_URL}}/api/v1/experiments", "host": ["{{BASE_URL}}"], "path": ["api","v1","experiments"]}
          }
        },
        {
          "name": "13. EXP b2_targeting: Submit → REVIEW",
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": [
            "pm.test('Status 200', function() { pm.response.to.have.status(200); });"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer {{ADMIN_TOKEN}}"}],
            "url": {"raw": "{{BASE_URL}}/api/v1/experiments/{{EXP_TARGETING_ID}}/submit", "host": ["{{BASE_URL}}"], "path": ["api","v1","experiments","{{EXP_TARGETING_ID}}","submit"]}
          }
        },
        {
          "name": "14. EXP b2_targeting: Review → APPROVED",
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": [
            "pm.test('Status 200', function() { pm.response.to.have.status(200); });"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{ADMIN_TOKEN}}"}],
            "body": {"mode": "raw", "raw": "{\n  \"decision\": \"ACCEPT\",\n  \"comment\": \"Seed B2.\"\n}"},
            "url": {"raw": "{{BASE_URL}}/api/v1/experiments/{{EXP_TARGETING_ID}}/review", "host": ["{{BASE_URL}}"], "path": ["api","v1","experiments","{{EXP_TARGETING_ID}}","review"]}
          }
        },
        {
          "name": "15. EXP b2_targeting: Start → RUNNING",
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": [
            "pm.test('Status 200', function() { pm.response.to.have.status(200); });"
          ]}}],
          "request": {
            "method": "POST",
