    {
      "name": "B2-5. Распределение по весам (30/70)",
      "description": "Для проверки распределения запустите ТОЛЬКО эту папку через Collection Runner с 100 итерациями.\n\nВ Postman: ПКМ на папке → Run folder → Iterations: 100 → Run.\n\nГде смотреть результаты:\n1. Test Results (вкладка после прогона) — тесты на последней итерации покажут точные числа и проценты\n2. Postman Console (View → Show Postman Console / Ctrl+Alt+C) — подробная таблица\n\nОжидаемый результат: control_val ~30%, treatment_val ~70% (допуск ±10%).",
      "item": [
        {
          "name": "B2-5: серия запросов (100 субъектов)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// pm.info.iteration — 0-based индекс текущей итерации в Collection Runner",
                  "var i = pm.info.iteration;",
                  "",
                  "// Устанавливаем номер для подстановки в тело запроса (1-based)",
                  "pm.variables.set('subjectIndex', i + 1);",
                  "",
                  "// Сброс счётчиков на первой итерации",
                  "if (i === 0) {",
                  "    pm.globals.set('b2_control', 0);",
                  "    pm.globals.set('b2_treatment', 0);",
                  "    pm.globals.set('b2_other', 0);",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var json = pm.response.json();",
                  "var val = json[0].value;",
                  "",
                  "// Обновляем счётчики в globals (они сохраняются между итерациями)",
                  "if (val === 'control_val') {",
                  "    pm.globals.set('b2_control', parseInt(pm.globals.get('b2_control') || '0') + 1);",
                  "} else if (val === 'treatment_val') {",
                  "    pm.globals.set('b2_treatment', parseInt(pm.globals.get('b2_treatment') || '0') + 1);",
                  "} else {",
                  "    pm.globals.set('b2_other', parseInt(pm.globals.get('b2_other') || '0') + 1);",
                  "}",
                  "",
                  "// На последней итерации — проверяем распределение и выводим результат",
                  "var isLast = pm.info.iteration === pm.info.iterationCount - 1;",
                  "if (isLast) {",
                  "    var control   = parseInt(pm.globals.get('b2_control'));",
                  "    var treatment = parseInt(pm.globals.get('b2_treatment'));",
                  "    var other     = parseInt(pm.globals.get('b2_other'));",
                  "    var total     = control + treatment;",
                  "    var controlPct   = total > 0 ? (control / total) * 100 : 0;",
                  "    var treatmentPct = total > 0 ? (treatment / total) * 100 : 0;",
                  "",
                  "    // Результат виден в Console (View → Show Postman Console)",
                  "    console.log('══════════════════════════════════════');",
                  "    console.log('  РЕЗУЛЬТАТ B2-5: Распределение по весам');",
                  "    console.log('──────────────────────────────────────');",
                  "    console.log('  control_val   (вес 30): ' + control + '  (' + controlPct.toFixed(1) + '%)');",
                  "    console.log('  treatment_val (вес 70): ' + treatment + '  (' + treatmentPct.toFixed(1) + '%)');",
                  "    if (other > 0) console.log('  other (default/cooldown): ' + other);",
                  "    console.log('══════════════════════════════════════');",
                  "",
                  "    // Результат виден в Test Results (зелёные/красные тесты)",
                  "    pm.test('control_val: ' + control + ' из ' + total + ' (' + controlPct.toFixed(1) + '%) — ожидание 20-40%', function () {",
                  "        pm.expect(controlPct).to.be.within(20, 40);",
                  "    });",
                  "",
                  "    pm.test('treatment_val: ' + treatment + ' из ' + total + ' (' + treatmentPct.toFixed(1) + '%) — ожидание 60-80%', function () {",
                  "        pm.expect(treatmentPct).to.be.within(60, 80);",
                  "    });",
                  "",
                  "    // Очистка временных globals",
                  "    pm.globals.unset('b2_control');",
                  "    pm.globals.unset('b2_treatment');",
                  "    pm.globals.unset('b2_other');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"weight-test-{{subjectIndex}}\",\n  \"subject_attr\": {},\n  \"flags_keys\": [\"b2_weights\"]\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/v1/decision",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "v1", "decision"]
            }
          }
        }
      ]
    }
