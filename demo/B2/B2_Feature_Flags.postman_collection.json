            "url": {"raw": "{{BASE_URL}}/api/v1/experiments/{{EXP_TARGETING_ID}}/start", "host": ["{{BASE_URL}}"], "path": ["api","v1","experiments","{{EXP_TARGETING_ID}}","start"]}
          }
        },
        {
          "name": "16. EXP b2_variant: Создать (DRAFT)",
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": [
            "pm.test('Status 201', function() { pm.response.to.have.status(201); });",
            "pm.collectionVariables.set('EXP_VARIANT_ID', pm.response.json().id);",
            "console.log('EXP_VARIANT_ID:', pm.response.json().id);"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{ADMIN_TOKEN}}"}],
