          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var json = pm.response.json();",
                  "var users = json.items;",
                  "",
                  "var exp = users.find(function(u) { return u.email === 'b1_experimenter@demo.com'; });",
                  "var apr = users.find(function(u) { return u.email === 'b1_approver@demo.com'; });",
                  "",
                  "if (exp) pm.collectionVariables.set('EXPERIMENTER_ID', exp.id);",
                  "if (apr) pm.collectionVariables.set('APPROVER_ID', apr.id);",
                  "",
                  "pm.test('Найден experimenter', function () { pm.expect(exp).to.not.be.undefined; });",
                  "pm.test('Найден approver', function () { pm.expect(apr).to.not.be.undefined; });"
                ]
