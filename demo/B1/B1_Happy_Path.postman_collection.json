{
  "info": {
    "name": "B1. Happy Path — полный цикл A/B теста",
    "description": "Пошаговый сценарий: логин → создание сущностей → запуск эксперимента → выдача вариантов → отправка событий → просмотр метрик.\n\nЗапросы выполняются **строго по порядку сверху вниз** (каждый следующий использует данные из предыдущего).\n\nПодготовка:\n1. docker compose up -d\n2. Задать переменную BASE_URL если отличается от http://localhost",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "BASE_URL",
      "value": "http://localhost",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Авторизация",
      "item": [
        {
          "name": "1.1 Login (admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('TOKEN', json.accessToken);",
                  "",
                  "pm.test('Получен accessToken', function () {",
                  "    pm.expect(json.accessToken).to.be.a('string').and.not.empty;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@mail.ru\",\n  \"password\": \"123123123aA!\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/v1/auth/login",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "v1", "auth", "login"]
            }
          }
        }
      ]
    },
