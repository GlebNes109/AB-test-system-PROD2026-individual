          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{ADMIN_TOKEN}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"type\": \"b6_click\",\n  \"description\": \"Клик по элементу\",\n  \"payload_schema\": {\"element\": \"string\"}\n}" },
            "url": { "raw": "{{BASE_URL}}/api/v1/events/types", "host": ["{{BASE_URL}}"], "path": ["api","v1","events","types"] }
          }
        },
        {
          "name": "0.08 Event type: b6_purchase (requires b6_click)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('201 or 409', function () { pm.expect([201,409]).to.include(pm.response.code); });"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{ADMIN_TOKEN}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"type\": \"b6_purchase\",\n  \"description\": \"Покупка\",\n  \"requires_event_type\": \"b6_click\",\n  \"payload_schema\": {\"amount\": \"number\"}\n}" },
            "url": { "raw": "{{BASE_URL}}/api/v1/events/types", "host": ["{{BASE_URL}}"], "path": ["api","v1","events","types"] }
          }
        },
        {
          "name": "0.09 Metric: b6_views_count",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
