            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{ADMIN_TOKEN}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"key\": \"b6_clicks_count\",\n  \"name\": \"Число кликов\",\n  \"description\": \"COUNT b6_click\",\n  \"event_type\": \"b6_click\",\n  \"aggregation\": \"COUNT\"\n}" },
            "url": { "raw": "{{BASE_URL}}/api/v1/metrics", "host": ["{{BASE_URL}}"], "path": ["api","v1","metrics"] }
          }
        },
        {
          "name": "0.11 Metric: b6_conversion (ratio)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('201 or 409', function () { pm.expect([201,409]).to.include(pm.response.code); });"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{ADMIN_TOKEN}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"key\": \"b6_conversion\",\n  \"name\": \"Конверсия (покупки / клики)\",\n  \"description\": \"COUNT b6_purchase / COUNT b6_click\",\n  \"event_type\": \"b6_purchase\",\n  \"aggregation\": \"COUNT\",\n  \"denominator_event_type\": \"b6_click\",\n  \"denominator_aggregation\": \"COUNT\"\n}" },
            "url": { "raw": "{{BASE_URL}}/api/v1/metrics", "host": ["{{BASE_URL}}"], "path": ["api","v1","metrics"] }
          }
        },
