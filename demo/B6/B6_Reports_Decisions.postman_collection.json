          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{ADMIN_TOKEN}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"key\": \"b6_views_count\",\n  \"name\": \"Число просмотров\",\n  \"description\": \"COUNT b6_page_view\",\n  \"event_type\": \"b6_page_view\",\n  \"aggregation\": \"COUNT\"\n}" },
            "url": { "raw": "{{BASE_URL}}/api/v1/metrics", "host": ["{{BASE_URL}}"], "path": ["api","v1","metrics"] }
          }
        },
