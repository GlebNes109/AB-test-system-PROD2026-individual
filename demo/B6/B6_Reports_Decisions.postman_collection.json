{
  "info": {
    "name": "B6. Отчёты и фиксация решений",
    "description": "Коллекция для проверки критериев B6 (отчёты по вариантам, фильтр по периоду, фиксация исхода).\n\nПорядок работы:\n1. Запустить папку «0. Data Generator» через Collection Runner (ПКМ → Run folder)\n2. Подождать ~5 секунд (обновление MV отчётов)\n3. Выполнять запросы B6-1 … B6-5 вручную сверху вниз\n\nПодготовка: docker compose up -d",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "BASE_URL", "value": "http://localhost", "type": "string" },
    { "key": "ADMIN_TOKEN", "value": "", "type": "string" },
    { "key": "EXPERIMENTER_TOKEN", "value": "", "type": "string" },
    { "key": "APPROVER_TOKEN", "value": "", "type": "string" },
    { "key": "EXPERIMENTER_ID", "value": "", "type": "string" },
    { "key": "APPROVER_ID", "value": "", "type": "string" },
    { "key": "EXP_REPORTS_ID", "value": "", "type": "string" },
    { "key": "EXP_FINISH_ID", "value": "", "type": "string" },
    { "key": "D1", "value": "", "type": "string" },
    { "key": "D2", "value": "", "type": "string" },
    { "key": "D3", "value": "", "type": "string" },
    { "key": "D4", "value": "", "type": "string" },
    { "key": "D5", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "0. Data Generator (Run folder)",
      "description": "ПКМ → Run folder → Run.\nСоздаёт пользователей, типы событий, метрики, флаги, 2 эксперимента (RUNNING), 5 decisions и события для EXP_REPORTS.\nПосле прогона подождите ~5 сек перед запросом отчётов.",
      "item": [
        {
          "name": "0.01 Login admin",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('200', function () { pm.response.to.have.status(200); });",
            "pm.collectionVariables.set('ADMIN_TOKEN', pm.response.json().accessToken);"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@mail.ru\",\n  \"password\": \"123123123aA!\"\n}" },
            "url": { "raw": "{{BASE_URL}}/api/v1/auth/login", "host": ["{{BASE_URL}}"], "path": ["api","v1","auth","login"] }
          }
        },
        {
          "name": "0.02 Create user: experimenter",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('201 or 409', function () { pm.expect([201,409]).to.include(pm.response.code); });"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{ADMIN_TOKEN}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"b6_experimenter@demo.com\",\n  \"password\": \"Demo1234!x\",\n  \"role\": \"EXPERIMENTER\"\n}" },
            "url": { "raw": "{{BASE_URL}}/api/v1/users", "host": ["{{BASE_URL}}"], "path": ["api","v1","users"] }
          }
        },
        {
          "name": "0.03 Create user: approver",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('201 or 409', function () { pm.expect([201,409]).to.include(pm.response.code); });"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{ADMIN_TOKEN}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"b6_approver@demo.com\",\n  \"password\": \"Demo1234!x\",\n  \"role\": \"APPROVER\"\n}" },
            "url": { "raw": "{{BASE_URL}}/api/v1/users", "host": ["{{BASE_URL}}"], "path": ["api","v1","users"] }
          }
        },
        {
          "name": "0.04 GET users → find IDs",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('200', function () { pm.response.to.have.status(200); });",
            "var users = pm.response.json().items;",
            "function findId(email) { var u = users.find(function(x){return x.email===email;}); return u ? u.id : null; }",
            "var expId = findId('b6_experimenter@demo.com');",
            "var aprId = findId('b6_approver@demo.com');",
            "if (expId) pm.collectionVariables.set('EXPERIMENTER_ID', expId);",
            "if (aprId) pm.collectionVariables.set('APPROVER_ID', aprId);"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{ADMIN_TOKEN}}" }],
            "url": { "raw": "{{BASE_URL}}/api/v1/users?size=100", "host": ["{{BASE_URL}}"], "path": ["api","v1","users"], "query": [{"key":"size","value":"100"}] }
          }
        },
        {
          "name": "0.05 Set approver group",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('200', function () { pm.response.to.have.status(200); });"
          ]}}],
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{ADMIN_TOKEN}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"approver_ids\": [\"{{APPROVER_ID}}\"],\n  \"min_approvals\": 1\n}" },
            "url": { "raw": "{{BASE_URL}}/api/v1/users/{{EXPERIMENTER_ID}}/approvers", "host": ["{{BASE_URL}}"], "path": ["api","v1","users","{{EXPERIMENTER_ID}}","approvers"] }
          }
        },
        {
          "name": "0.06 Event type: b6_page_view",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('201 or 409', function () { pm.expect([201,409]).to.include(pm.response.code); });"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{ADMIN_TOKEN}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"type\": \"b6_page_view\",\n  \"description\": \"Просмотр страницы\"\n}" },
            "url": { "raw": "{{BASE_URL}}/api/v1/events/types", "host": ["{{BASE_URL}}"], "path": ["api","v1","events","types"] }
          }
        },
        {
          "name": "0.07 Event type: b6_click",
