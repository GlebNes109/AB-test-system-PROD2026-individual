    {
      "name": "B4-1. Валидация типов полей",
      "description": "b4_click имеет payload_schema: {button_id: string}. Отправляем число вместо строки.",
      "item": [
        {
          "name": "B4-1a: Неверный тип (button_id: число → 422)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 207', function () { pm.response.to.have.status(207); });",
            "var r = pm.response.json().results[0];",
            "pm.test('status_code = 422 — невалидный payload', function () {",
            "    pm.expect(r.status_code).to.eql(422);",
            "});",
            "pm.test('event_status = REJECTED', function () {",
            "    pm.expect(r.event_status).to.eql('REJECTED');",
            "});",
            "pm.test('error содержит описание ошибки типа', function () {",
            "    pm.expect(r.error).to.be.a('string').and.not.empty;",
            "});",
            "console.log('B4-1a: Отклонено — ' + r.error);"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"events\": [\n    {\n      \"event_type\": \"b4_click\",\n      \"decision_id\": \"{{DECISION_ID}}\",\n      \"payload\": {\"button_id\": 12345}\n    }\n  ]\n}" },
            "url": { "raw": "{{BASE_URL}}/api/v1/events/batch", "host": ["{{BASE_URL}}"], "path": ["api","v1","events","batch"] }
          }
        },
        {
          "name": "B4-1b: Валидный payload (button_id: строка → 201)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 207', function () { pm.response.to.have.status(207); });",
            "var r = pm.response.json().results[0];",
            "pm.test('status_code = 201 — принято', function () {",
            "    pm.expect(r.status_code).to.eql(201);",
            "});",
            "pm.test('event_status = RECEIVED', function () {",
            "    pm.expect(r.event_status).to.eql('RECEIVED');",
            "});",
            "console.log('B4-1b: Валидный click принят, event_id=' + r.event_id);"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"events\": [\n    {\n      \"event_type\": \"b4_click\",\n      \"decision_id\": \"{{DECISION_ID}}\",\n      \"payload\": {\"button_id\": \"buy-button-01\"}\n    }\n  ]\n}" },
            "url": { "raw": "{{BASE_URL}}/api/v1/events/batch", "host": ["{{BASE_URL}}"], "path": ["api","v1","events","batch"] }
          }
        }
      ]
    },
    {
      "name": "B4-2. Валидация обязательных полей",
      "description": "b4_purchase имеет payload_schema: {amount: number, currency: string}. Отправляем без currency.",
      "item": [
        {
          "name": "B4-2a: Decision для b4-user-beta",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('200', function () { pm.response.to.have.status(200); });",
            "var json = pm.response.json();",
            "pm.collectionVariables.set('DECISION_BETA', json[0].id);",
            "console.log('B4-2: DECISION_BETA=' + json[0].id);"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"id\": \"b4-user-beta\",\n  \"subject_attr\": {},\n  \"flags_keys\": [\"b4_checkout_flow\"]\n}" },
            "url": { "raw": "{{BASE_URL}}/api/v1/decision", "host": ["{{BASE_URL}}"], "path": ["api","v1","decision"] }
          }
        },
        {
          "name": "B4-2b: Отсутствует поле currency (→ 422)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 207', function () { pm.response.to.have.status(207); });",
            "var r = pm.response.json().results[0];",
            "pm.test('status_code = 422 — пропущено обязательное поле', function () {",
            "    pm.expect(r.status_code).to.eql(422);",
            "});",
            "pm.test('event_status = REJECTED', function () {",
