{
  "info": {
    "name": "B4. События и атрибуция",
    "description": "Коллекция для проверки критериев B4 (валидация событий, дедупликация, атрибуция конверсий).\n\nПорядок работы:\n1. Запустить папку «0. Data Generator» через Collection Runner (ПКМ → Run folder) — создаст эксперимент, decision и сохранит все ID/токены\n2. Выполнять запросы B4-1 … B4-5 вручную по одному сверху вниз\n\nПодготовка: docker compose up -d",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "BASE_URL", "value": "http://localhost", "type": "string" },
    { "key": "ADMIN_TOKEN", "value": "", "type": "string" },
    { "key": "EXPERIMENTER_TOKEN", "value": "", "type": "string" },
    { "key": "APPROVER_TOKEN", "value": "", "type": "string" },
    { "key": "EXPERIMENTER_ID", "value": "", "type": "string" },
    { "key": "APPROVER_ID", "value": "", "type": "string" },
    { "key": "EXP_ID", "value": "", "type": "string" },
    { "key": "DECISION_ID", "value": "", "type": "string" },
    { "key": "DECISION_ALPHA_VALUE", "value": "", "type": "string" },
    { "key": "DECISION_BETA", "value": "", "type": "string" },
    { "key": "DECISION_GAMMA", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "0. Data Generator (Run folder)",
      "description": "ПКМ → Run folder → Run.\nСоздаёт пользователей, типы событий (с payload_schema и зависимостями), метрики, флаг, эксперимент (RUNNING) и decision.\nВсе ID и токены сохраняются в переменные коллекции.",
      "item": [
        {
          "name": "0.01 Login admin",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('200', function () { pm.response.to.have.status(200); });",
            "pm.collectionVariables.set('ADMIN_TOKEN', pm.response.json().accessToken);"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@mail.ru\",\n  \"password\": \"123123123aA!\"\n}" },
            "url": { "raw": "{{BASE_URL}}/api/v1/auth/login", "host": ["{{BASE_URL}}"], "path": ["api","v1","auth","login"] }
          }
        },
        {
          "name": "0.02 Create user: experimenter",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('201 or 409', function () { pm.expect([201,409]).to.include(pm.response.code); });"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{ADMIN_TOKEN}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"b4_experimenter@demo.com\",\n  \"password\": \"Demo1234!x\",\n  \"role\": \"EXPERIMENTER\"\n}" },
            "url": { "raw": "{{BASE_URL}}/api/v1/users", "host": ["{{BASE_URL}}"], "path": ["api","v1","users"] }
          }
        },
        {
          "name": "0.03 Create user: approver",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('201 or 409', function () { pm.expect([201,409]).to.include(pm.response.code); });"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{ADMIN_TOKEN}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"b4_approver@demo.com\",\n  \"password\": \"Demo1234!x\",\n  \"role\": \"APPROVER\"\n}" },
            "url": { "raw": "{{BASE_URL}}/api/v1/users", "host": ["{{BASE_URL}}"], "path": ["api","v1","users"] }
          }
        },
        {
          "name": "0.04 GET users → find IDs",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('200', function () { pm.response.to.have.status(200); });",
            "var users = pm.response.json().items;",
            "function findId(email) { var u = users.find(function(x){return x.email===email;}); return u ? u.id : null; }",
            "var expId = findId('b4_experimenter@demo.com');",
            "var aprId = findId('b4_approver@demo.com');",
            "if (expId) pm.collectionVariables.set('EXPERIMENTER_ID', expId);",
            "if (aprId) pm.collectionVariables.set('APPROVER_ID', aprId);",
            "pm.test('Found experimenter', function () { pm.expect(expId).to.not.be.null; });",
            "pm.test('Found approver', function () { pm.expect(aprId).to.not.be.null; });"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{ADMIN_TOKEN}}" }],
            "url": { "raw": "{{BASE_URL}}/api/v1/users?size=100", "host": ["{{BASE_URL}}"], "path": ["api","v1","users"], "query": [{"key":"size","value":"100"}] }
          }
        },
        {
          "name": "0.05 Set approver group",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('200', function () { pm.response.to.have.status(200); });"
